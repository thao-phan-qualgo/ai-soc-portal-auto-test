{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "paths": {
      "@pages/*": [
        "./src/pages/*"
      ],
      "@fixtures/*": [
        "./src/fixtures/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@config/*": [
        "./src/config/*"
      ],
      "@tests/*": [
        "./src/tests/*"
      ],
      "@database/*": [
        "./src/database/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "step-definitions/**/*.ts",
    "features/**/*.ts",
    "playwright.config.ts",
    "cucumber.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "allure-results",
    "allure-report",
    "test-results",
    "reports",
    "examples"
  ]
}