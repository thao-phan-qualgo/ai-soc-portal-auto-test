{
  "name": "ai-soc-portal-auto-test",
  "version": "1.0.0",
  "description": "AI SOC Portal Automated Testing Framework with TypeScript and Playwright",
  "scripts": {
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --grep @smoke",
    "test:chrome": "playwright test --project=chromium --headed",
    "test:gherkin:login": "cucumber-js --config=cucumber.config.js --tags @login",
    "test:gherkin:db": "cucumber-js --config=cucumber.config.js --tags @database",
    "tunnel:start": "./ssh-tunnel.sh start",
    "tunnel:stop": "./ssh-tunnel.sh stop",
    "tunnel:status": "./ssh-tunnel.sh status",
    "tunnel:restart": "./ssh-tunnel.sh restart",
    "report": "playwright show-report",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "codegen": "playwright codegen https://dev-aisoc-fe.qualgo.dev",
    "install:browsers": "playwright install",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "e2e-testing",
    "ai-soc-portal"
  ],
  "author": "QualGo Team",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@playwright/test": "^1.40.0",
    "@types/cucumber": "^6.0.1",
    "@types/node": "^20.19.23",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "allure-playwright": "^2.15.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "mysql2": "^3.6.5",
    "pg": "^8.11.3",
    "sqlite3": "^5.1.6"
  }
}
