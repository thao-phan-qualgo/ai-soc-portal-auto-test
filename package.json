{
  "name": "ai-soc-portal-auto-test",
  "version": "1.0.0",
  "description": "AI SOC Portal Automated Testing Framework with TypeScript and Playwright",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test --grep @smoke",
    "test:ui": "playwright test --ui",
    "test:chrome": "playwright test --project=chromium --headed",
    "test:firefox": "echo 'Firefox tests disabled - only Chromium is enabled'",
    "test:webkit": "echo 'WebKit tests disabled - only Chromium is enabled'",
    "test:all-browsers": "playwright test --project=chromium",
    "test:data": "playwright test tests/data/ --grep @database",
    "test:e2e": "playwright test tests/e2e/ --grep @e2e",
    "test:integration": "playwright test tests/integration/ --grep @integration",
    "test:unit": "playwright test tests/unit/ --grep @unit",
    "test:api": "playwright test tests/api/ --grep @api",
    "test:performance": "playwright test tests/performance/ --grep @performance",
    "test:ui": "playwright test tests/ui/ --grep @ui",
    "test:it-asset": "playwright test tests/e2e/it-asset-inventory.spec.ts --headed",
    "demo:backend-auth": "npx ts-node examples/backend-auth-example.ts",
    "demo:selectors": "npx ts-node examples/selector-usage-example.ts",
    "report": "playwright show-report",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "codegen": "playwright codegen https://dev-aisoc-fe.qualgo.dev",
    "install:browsers": "playwright install",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "e2e-testing",
    "ai-soc-portal"
  ],
  "author": "QualGo Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "allure-playwright": "^2.15.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "faker": "^5.5.3",
    "@faker-js/faker": "^8.3.1"
  }
}

